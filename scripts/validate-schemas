#!/bin/sh
set -eu

repo_dir=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)

if command -v mise >/dev/null 2>&1; then
  exec mise exec -- cargo test --manifest-path "$repo_dir/Cargo.toml" --test schema_fixtures
fi

if ! command -v cargo >/dev/null 2>&1; then
  echo "error: Rust 1.97.1 is required (install mise for the pinned toolchain)" >&2
  exit 1
fi

exec cargo test --manifest-path "$repo_dir/Cargo.toml" --test schema_fixtures
