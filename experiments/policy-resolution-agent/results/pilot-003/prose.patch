@@ -93,3 +93,30 @@ impl Policy {
 fn pattern_matches(pattern: &str, value: &str) -> bool {
     pattern == "*" || pattern == value
 }
+
+fn compare_rules(left: &Rule, right: &Rule) -> std::cmp::Ordering {
+    rule_rank(left)
+        .cmp(&rule_rank(right))
+        .then_with(|| effect_rank(left.effect).cmp(&effect_rank(right.effect)))
+        .then_with(|| right.id.cmp(&left.id))
+}
+
+fn rule_rank(rule: &Rule) -> (u8, i32) {
+    let specificity = [
+        rule.subject != "*",
+        rule.action != "*",
+        rule.resource != "*",
+    ]
+    .into_iter()
+    .map(u8::from)
+    .sum();
+
+    (specificity, rule.priority)
+}
+
+fn effect_rank(effect: Effect) -> u8 {
+    match effect {
+        Effect::Deny => 1,
+        Effect::Allow => 0,
+    }
+}
