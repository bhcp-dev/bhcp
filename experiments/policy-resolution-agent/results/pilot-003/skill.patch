@@ -93,3 +93,32 @@ impl Policy {
 fn pattern_matches(pattern: &str, value: &str) -> bool {
     pattern == "*" || pattern == value
 }
+
+fn compare_rules(left: &Rule, right: &Rule) -> std::cmp::Ordering {
+    use std::cmp::Ordering;
+
+    specificity(left)
+        .cmp(&specificity(right))
+        .then_with(|| left.priority.cmp(&right.priority))
+        .then_with(|| effect_rank(left.effect).cmp(&effect_rank(right.effect)))
+        .then_with(|| right.id.cmp(&left.id))
+        .then(Ordering::Equal)
+}
+
+fn specificity(rule: &Rule) -> usize {
+    [
+        rule.subject.as_str(),
+        rule.action.as_str(),
+        rule.resource.as_str(),
+    ]
+    .into_iter()
+    .filter(|pattern| *pattern != "*")
+    .count()
+}
+
+fn effect_rank(effect: Effect) -> u8 {
+    match effect {
+        Effect::Deny => 1,
+        Effect::Allow => 0,
+    }
+}
