+fn compare_rules(left: &Rule, right: &Rule) -> Ordering {
+    context_specificity(left)
+        .cmp(&context_specificity(right))
+        .then(left.priority.cmp(&right.priority))
+        .then_with(|| compare_effects(left.effect, right.effect))
+        .then_with(|| right.id.cmp(&left.id))
+}
+
+fn context_specificity(rule: &Rule) -> (bool, bool, bool) {
+    (
+        rule.resource.as_str() != "*",
+        rule.subject.as_str() != "*",
+        rule.action.as_str() != "*",
+    )
+}
+
+fn compare_effects(left: Effect, right: Effect) -> Ordering {
+    match (left, right) {
+        (Effect::Deny, Effect::Allow) => Ordering::Greater,
+        (Effect::Allow, Effect::Deny) => Ordering::Less,
+        _ => Ordering::Equal,
+    }
 }

