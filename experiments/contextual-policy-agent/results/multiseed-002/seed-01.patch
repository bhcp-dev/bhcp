+fn compare_rules(left: &Rule, right: &Rule) -> std::cmp::Ordering {
+    specificity_key(left)
+        .cmp(&specificity_key(right))
+        .then(left.priority.cmp(&right.priority))
+        .then(effect_rank(left.effect).cmp(&effect_rank(right.effect)))
+        .then(right.id.cmp(&left.id))
+}
+
+fn specificity_key(rule: &Rule) -> (u8, u8, u8) {
+    (
+        field_specificity(&rule.resource),
+        field_specificity(&rule.subject),
+        field_specificity(&rule.action),
+    )
+}
+
+fn field_specificity(pattern: &str) -> u8 {
+    u8::from(pattern != "*")
+}
+
+fn effect_rank(effect: Effect) -> u8 {
+    match effect {
+        Effect::Allow => 0,
+        Effect::Deny => 1,
+    }
 }
