+fn compare_rules(
+    left: &Rule,
+    right: &Rule,
+    subject: &str,
+    action: &str,
+    resource: &str,
+) -> Ordering {
+    rule_specificity(left, subject, action, resource)
+        .cmp(&rule_specificity(right, subject, action, resource))
+        .then_with(|| left.priority.cmp(&right.priority))
+        .then_with(|| effect_rank(left.effect).cmp(&effect_rank(right.effect)))
+        .then_with(|| right.id.cmp(&left.id))
+}
+
+fn rule_specificity(rule: &Rule, subject: &str, action: &str, resource: &str) -> (u8, u8, u8) {
+    (
+        exact_match_score(&rule.resource, resource),
+        exact_match_score(&rule.subject, subject),
+        exact_match_score(&rule.action, action),
+    )
+}
+
+fn exact_match_score(pattern: &str, value: &str) -> u8 {
+    u8::from(pattern == value)
+}
+
+fn effect_rank(effect: Effect) -> u8 {
+    match effect {
+        Effect::Allow => 0,
+        Effect::Deny => 1,
+    }
 }
