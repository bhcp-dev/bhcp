-    .count()
+fn compare_rules(left: &Rule, right: &Rule) -> std::cmp::Ordering {
+    use std::cmp::Ordering;
+
+    let left_specificity = (
+        is_exact(&left.resource),
+        is_exact(&left.subject),
+        is_exact(&left.action),
+    );
+    let right_specificity = (
+        is_exact(&right.resource),
+        is_exact(&right.subject),
+        is_exact(&right.action),
+    );
+
+    left_specificity
+        .cmp(&right_specificity)
+        .then_with(|| left.priority.cmp(&right.priority))
+        .then_with(|| match (left.effect, right.effect) {
+            (Effect::Deny, Effect::Allow) => Ordering::Greater,
+            (Effect::Allow, Effect::Deny) => Ordering::Less,
+            _ => Ordering::Equal,
+        })
+        .then_with(|| right.id.cmp(&left.id))
+}
+
+fn is_exact(pattern: &str) -> bool {
+    pattern != "*"
+}
