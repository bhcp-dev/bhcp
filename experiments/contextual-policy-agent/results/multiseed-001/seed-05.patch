+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    fn allow_rule(
+        id: &str,
+        tenant: &str,
+        subject: &str,
+        action: &str,
+        resource: &str,
+        priority: i32,
+    ) -> Rule {
+        Rule::new(
+            id,
+            tenant,
+            subject,
+            action,
+            resource,
+            priority,
+            Effect::Allow,
+        )
+    }
+
+    fn deny_rule(
+        id: &str,
+        tenant: &str,
+        subject: &str,
+        action: &str,
+        resource: &str,
+        priority: i32,
+    ) -> Rule {
+        Rule::new(
+            id,
+            tenant,
+            subject,
+            action,
+            resource,
+            priority,
+            Effect::Deny,
+        )
+    }
+
+    #[test]
+    fn ignores_other_tenants() {
+        let policy = Policy::new([allow_rule("a", "tenant-a", "alice", "read", "doc", 1)]);
+
+        assert_eq!(
+            policy.decide("tenant-b", "alice", "read", "doc"),
+            Decision {
+                effect: Effect::Deny,
+                rule_id: None,
+            }
+        );
+    }
+
+    #[test]
+    fn prefers_more_specific_resource() {
+        let policy = Policy::new([
+            allow_rule("wild", "tenant", "alice", "read", "*", 10),
+            deny_rule("specific", "tenant", "alice", "read", "doc", 1),
+        ]);
+
+        assert_eq!(
+            policy.decide("tenant", "alice", "read", "doc"),
+            Decision {
+                effect: Effect::Deny,
+                rule_id: Some("specific".to_string()),
+            }
+        );
+    }
+
+    #[test]
+    fn priority_breaks_equal_specificity() {
+        let policy = Policy::new([
+            allow_rule("low", "tenant", "alice", "read", "doc", 1),
+            deny_rule("high", "tenant", "alice", "read", "doc", 2),
+        ]);
+
+        assert_eq!(
+            policy.decide("tenant", "alice", "read", "doc"),
+            Decision {
+                effect: Effect::Deny,
+                rule_id: Some("high".to_string()),
+            }
+        );
+    }
+
+    #[test]
+    fn deny_wins_when_all_other_factors_tie() {
+        let policy = Policy::new([
+            allow_rule("allow", "tenant", "alice", "read", "doc", 1),
+            deny_rule("deny", "tenant", "alice", "read", "doc", 1),
+        ]);
+
+        assert_eq!(
+            policy.decide("tenant", "alice", "read", "doc"),
+            Decision {
+                effect: Effect::Deny,
+                rule_id: Some("deny".to_string()),
+            }
+        );
+    }
+
+    #[test]
+    fn smaller_rule_id_breaks_final_tie() {
+        let policy = Policy::new([
+            allow_rule("b", "tenant", "alice", "read", "doc", 1),
+            allow_rule("a", "tenant", "alice", "read", "doc", 1),
+        ]);
+
+        assert_eq!(
+            policy.decide("tenant", "alice", "read", "doc"),
+            Decision {
+                effect: Effect::Allow,
+                rule_id: Some("a".to_string()),
+            }
+        );
+    }
+
+    #[test]
+    fn denies_when_no_rule_is_eligible() {
+        let policy = Policy::new([allow_rule("a", "tenant", "alice", "read", "doc", 1)]);
+
+        assert_eq!(
+            policy.decide("tenant", "bob", "read", "doc"),
+            Decision {
+                effect: Effect::Deny,
+                rule_id: None,
+            }
+        );
+    }
 }
